default_platform(:ios)

# The app and its two extensions all ship in the same TestFlight build.
APP_IDENTIFIERS = [
  "co.gitwork.post",
  "co.gitwork.post.ShareExtension",
  "co.gitwork.post.PhotosExtension",
].freeze

platform :ios do
  desc "Build the app and upload a beta build to TestFlight"
  lane :beta do
    # App Store Connect API key — used both for cloud signing (-allowProvisioningUpdates)
    # and for the TestFlight upload, so no Apple ID / app-specific password is needed.
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false
    )

    # Monotonic build number so each upload is accepted by TestFlight. The marketing
    # version (MARKETING_VERSION) stays in project.yml; only the build number bumps here.
    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s

    build_app(
      scheme: "Post",
      xcodeproj: "Post.xcodeproj",
      export_method: "app-store",
      output_directory: "build",
      api_key: api_key,
      # Xcode manages the distribution cert + App Store profiles for all three bundle
      # IDs via the API key. CURRENT_PROJECT_VERSION feeds every target's build number.
      xcargs: "-allowProvisioningUpdates CURRENT_PROJECT_VERSION=#{build_number}",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV.fetch("APPLE_TEAM_ID")
      }
    )

    upload_to_testflight(
      api_key: api_key,
      # Don't block the runner waiting for Apple's server-side processing.
      skip_waiting_for_build_processing: true
    )
  end
end
